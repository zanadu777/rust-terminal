<UserControl x:Class="RustTerminal.RecentCommands"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:RustTerminal"
             mc:Ignorable="d"
             d:DesignHeight="300"
             d:DesignWidth="800">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0"
                   Grid.Column="0"
                   Text="Recent Commands"
                   FontSize="14"
                   FontWeight="Bold"
                   VerticalAlignment="Center" />

        <CheckBox Grid.Row="0"
                  Grid.Column="1"
                  IsChecked="{Binding FilterByDirectory}"
                  Content="Filter by Directory"
                  VerticalAlignment="Center"
                  Margin="8,0,0,0" />

        <ItemsControl Grid.Row="1"
                      Grid.ColumnSpan="2"
                      ItemsSource="{Binding RecentCommands}"
                      Margin="0,8,0,0">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:RecentCommands}}, Path=DataContext.ExecuteRecentCommandCommand}"
                            CommandParameter="{Binding Command}"
                            Padding="10,6"
                            Margin="0,0,0,8"
                            ToolTip="{Binding Command, StringFormat='Run: {0}'}">
                        <TextBlock Text="{Binding Command}"
                                   TextTrimming="CharacterEllipsis" />
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
