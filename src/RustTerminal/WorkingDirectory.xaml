<UserControl x:Class="RustTerminal.WorkingDirectory"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:RustTerminal"
             mc:Ignorable="d"
             d:DesignHeight="56"
             d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0"
                   Grid.Column="0"
                   VerticalAlignment="Center"
                   Text="Working Directory" />

        <ComboBox x:Name="PathCombo"
                  Grid.Row="0"
                  Grid.Column="2"
                  IsEditable="True"
                  StaysOpenOnEdit="False"
                  IsTextSearchEnabled="False"
                  ItemsSource="{Binding Paths, RelativeSource={RelativeSource AncestorType={x:Type local:WorkingDirectory}}}"
                  SelectedItem="{Binding Path, RelativeSource={RelativeSource AncestorType={x:Type local:WorkingDirectory}}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                  Text="{Binding Path, RelativeSource={RelativeSource AncestorType={x:Type local:WorkingDirectory}}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                  KeyDown="PathCombo_KeyDown" />

        <Button Grid.Row="0"
                Grid.Column="4"
                Padding="10,2"
                Content="Browse..."
                Command="{Binding BrowseCommand, RelativeSource={RelativeSource AncestorType={x:Type local:WorkingDirectory}}}" />

        <TextBlock Grid.Row="1"
                   Grid.Column="2"
                   Grid.ColumnSpan="3"
                   Margin="0,4,0,0"
                   Foreground="DarkOrange"
                   Text="Type or pick an existing directory. New value is saved only if it exists." />
    </Grid>
</UserControl>
